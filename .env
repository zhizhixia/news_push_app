# 阿里云百炼大语言模型配置
# 从 https://dashscope.console.aliyun.com/ 获取
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 微信公众号配置
# 从 https://mp.weixin.qq.com/ 获取
# WECHAT_TOKEN: 自定义的验证令牌（3-32位字符）
WECHAT_TOKEN=your_custom_token_here
# WECHAT_APPID: 微信公众号的应用ID（类似 wx1234567890abcdef）
WECHAT_APPID=your_wechat_appid_here
# WECHAT_APPSECRET: 微信公众号的应用密钥
WECHAT_APPSECRET=your_wechat_appsecret_here

# MCP服务配置
# 注意：以下MCP服务已开通，无需额外配置API Key
# - 墨迹天气MCP服务 (提供天气数据)
# - 城市热点新闻MCP服务 (提供新闻资讯)
# - 高德地图MCP Server (提供地理位置服务)

# 应用配置
DEFAULT_CITY=北京
PUSH_TIME_HOUR=8
PUSH_TIME_MINUTE=0

# 日志配置
LOG_LEVEL=INFO

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 开发环境配置
DEBUG=true
RELOAD=true